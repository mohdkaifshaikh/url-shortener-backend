<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Snip — URL Shortener</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0d0d0f;
      --surface:  #16161a;
      --border:   #2a2a32;
      --accent:   #7c5cfc;
      --accent-2: #a78bfa;
      --text:     #e8e8f0;
      --muted:    #6b6b80;
      --success:  #22c55e;
      --error:    #f87171;
      --mono:     'JetBrains Mono', monospace;
      --sans:     'Space Grotesk', sans-serif;
      --radius:   12px;
    }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 20px 80px;
    }

    /* ── Header ── */
    header {
      text-align: center;
      margin-bottom: 52px;
    }

    .logo {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }

    .logo-icon {
      width: 36px; height: 36px;
      background: var(--accent);
      border-radius: 8px;
      display: grid;
      place-items: center;
    }

    .logo-icon svg { width: 20px; height: 20px; }

    .logo-name {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    header h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-bottom: 16px;
    }

    header h1 span {
      background: linear-gradient(120deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    header p {
      color: var(--muted);
      font-size: 1.05rem;
      max-width: 420px;
      margin: 0 auto;
      line-height: 1.6;
    }

    /* ── Card ── */
    .card {
      width: 100%;
      max-width: 600px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 32px;
      margin-bottom: 32px;
    }

    /* ── Form ── */
    .form-label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .input-row {
      display: flex;
      gap: 10px;
    }

    input[type="url"], input[type="text"] {
      flex: 1;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--text);
      font-family: var(--mono);
      font-size: 0.9rem;
      padding: 14px 16px;
      outline: none;
      transition: border-color 0.2s;
    }

    input[type="url"]:focus, input[type="text"]:focus {
      border-color: var(--accent);
    }

    input::placeholder { color: var(--muted); }

    .btn {
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      font-family: var(--sans);
      font-size: 0.95rem;
      font-weight: 600;
      padding: 14px 24px;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
      white-space: nowrap;
    }

    .btn:hover  { opacity: 0.88; }
    .btn:active { transform: scale(0.97); }

    /* Custom alias (optional) */
    .alias-row {
      display: flex;
      align-items: center;
      margin-top: 16px;
      gap: 0;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .alias-prefix {
      padding: 14px 14px 14px 16px;
      font-family: var(--mono);
      font-size: 0.85rem;
      color: var(--muted);
      background: var(--surface);
      border-right: 1px solid var(--border);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .alias-row input {
      border: none;
      border-radius: 0;
      background: transparent;
      flex: 1;
      padding-left: 12px;
    }

    .alias-row input:focus { border-color: transparent; }

    /* ── Flash Messages ── */
    .flash {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 14px 16px;
      border-radius: var(--radius);
      font-size: 0.9rem;
      margin-bottom: 20px;
    }

    .flash-success {
      background: rgba(34,197,94,.1);
      border: 1px solid rgba(34,197,94,.25);
      color: var(--success);
    }

    .flash-error {
      background: rgba(248,113,113,.1);
      border: 1px solid rgba(248,113,113,.25);
      color: var(--error);
    }

    /* ── Result Box ── */
    .result-box {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px;
      margin-top: 24px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .result-url {
      font-family: var(--mono);
      font-size: 0.92rem;
      color: var(--accent-2);
      flex: 1;
      word-break: break-all;
    }

    .btn-copy {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.8rem;
      font-weight: 600;
      padding: 8px 14px;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
      flex-shrink: 0;
    }

    .btn-copy:hover { border-color: var(--accent); color: var(--text); }
    .btn-copy.copied { border-color: var(--success); color: var(--success); }

    /* ── Stats ── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .stat-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      text-align: center;
    }

    .stat-value {
      font-size: 1.8rem;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--text);
      line-height: 1;
      margin-bottom: 6px;
    }

    .stat-label {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* ── Link Table ── */
    .section-title {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 16px;
    }

    .link-list { display: flex; flex-direction: column; gap: 10px; }

    .link-item {
      display: flex;
      align-items: center;
      gap: 14px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      transition: border-color 0.2s;
    }

    .link-item:hover { border-color: #3a3a48; }

    .link-short {
      font-family: var(--mono);
      font-size: 0.88rem;
      color: var(--accent-2);
      font-weight: 500;
      min-width: 140px;
      flex-shrink: 0;
    }

    .link-original {
      font-size: 0.85rem;
      color: var(--muted);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      flex: 1;
    }

    .link-clicks {
      font-family: var(--mono);
      font-size: 0.82rem;
      color: var(--muted);
      flex-shrink: 0;
    }

    .link-delete {
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      padding: 4px;
      border-radius: 6px;
      line-height: 0;
      transition: color 0.15s;
      flex-shrink: 0;
    }

    .link-delete:hover { color: var(--error); }

    /* empty state */
    .empty {
      text-align: center;
      padding: 40px 20px;
      color: var(--muted);
      font-size: 0.9rem;
    }

    /* ── Footer ── */
    footer {
      margin-top: auto;
      padding-top: 48px;
      font-size: 0.8rem;
      color: var(--muted);
    }

    /* ── Responsive ── */
    @media (max-width: 500px) {
      .input-row { flex-direction: column; }
      .btn { width: 100%; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .link-short { min-width: 100px; }
    }
  </style>
</head>
<body>

  <!-- ── Header ── -->
  <header>
    <div class="logo">
      <div class="logo-icon">
        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 4H5a3 3 0 000 6h3M12 16h3a3 3 0 000-6h-3M7 10h6" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="logo-name">Snip</span>
    </div>
    <h1>Short links,<br/><span>big reach</span></h1>
    <p>Paste a long URL and get a clean, shareable link in seconds.</p>
  </header>

  <!-- ── Main Card ── -->
  <div class="card">

    <!-- Flash messages -->
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="flash flash-success">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <%= success %>
      </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="flash flash-error">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <%= error %>
      </div>
    <% } %>

    <!-- Shorten form -->
    <label class="form-label" for="originalUrl">Paste your URL</label>
    <form action="/shorten" method="POST">
      <div class="input-row">
        <input
          type="url"
          id="originalUrl"
          name="originalUrl"
          placeholder="https://example.com/very/long/url"
          required
          value="<%= typeof formData !== 'undefined' ? formData.originalUrl || '' : '' %>"
        />
        <button type="submit" class="btn">Shorten</button>
      </div>
      <!-- Custom alias (optional) -->
<div class="alias-row">
  <span class="alias-prefix"><%= typeof baseUrl !== 'undefined' ? baseUrl : 'snip.ly' %>/</span>
  <input
    type="text"
    name="customAlias"
    placeholder="custom-alias (optional)"
    pattern="[a-zA-Z0-9_-]{3,30}"
    title="Letters, numbers, hyphens and underscores only"
    value="<%= typeof formData !== 'undefined' ? formData.customAlias || '' : '' %>"
  />
</div>
    </form>

    <!-- Result (shown after successful shortening) -->
    <% if (typeof shortUrl !== 'undefined' && shortUrl) { %>
      <div class="result-box">
        <span class="result-url" id="shortUrlText"><%= shortUrl %></span>
        <button 
        class="btn-copy"
        onclick="copyUrl(this, '<%= shortUrl %>')"
        >Copy</button>
      </div>
    <% } %>

  </div>

  <!-- ── Stats ── -->
  <% if (typeof stats !== 'undefined' && stats) { %>
  <div class="card">
    <div class="section-title">Overview</div>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= stats.totalLinks || 0 %></div>
        <div class="stat-label">Links</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.totalClicks || 0 %></div>
        <div class="stat-label">Total Clicks</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.activeToday || 0 %></div>
        <div class="stat-label">Active Today</div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ── Recent Links ── -->
  <div class="card">
    <div class="section-title">Recent links</div>

    <% if (typeof links !== 'undefined' && links && links.length > 0) { %>
      <div class="link-list">
        <% links.forEach(function(link) { %>
          <div class="link-item">
            <span class="link-short"><%= baseUrl || '' %>/<%= link.shortCode %></span>
            <span class="link-original"><%= link.originalUrl %></span>
            <span class="link-clicks"><%= link.clicks || 0 %> clicks</span>
            <button
              class="link-delete"
              onclick="deleteLink('<%= link.shortCode %>')"
              title="Delete link"
            >
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24">
                <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty">No links yet — shorten your first URL above.</div>
    <% } %>
  </div>
  <script>
    // ── Copy to clipboard ──
    function copyUrl(btn, url) {
      navigator.clipboard.writeText(url).then(() => {
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      });
    }

    // ── Delete link ──
    function deleteLink(shortCode) {
      if (!confirm('Delete this link?')) return;
      fetch('/delete/' + shortCode, { method: 'DELETE' })
        .then(res => {
          if (res.ok) location.reload();
          else alert('Could not delete link.');
        });
    }
  </script>

</body>
</html>
